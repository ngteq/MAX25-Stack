#!/usr/bin/env bash
# MainAX25-Stack (MAX25-Stack) — unified control entry point for Packet Radio / AX.25 stacks.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

MODE="${MAX25_MODE:-standalone}"
HARDWARE=""
DEVICE=""
ACTION="${1:-help}"
shift || true

usage() {
  cat <<EOF
MainAX25-Stack (MAX25-Stack) control — Packet Radio / AX.25 (HyBBX-compatible)

Usage:
  max25-ctl <command> [options]

Commands:
  help              This help
  discover          List plugins
  build             Build all stacks
  start             Start hardware stack
  stop              Stop hardware stack
  status            Show stack status
  test              Offline tests (no root)

Options (start/stop/status):
  --mode MODE       standalone | service | hybbx-edge  (default: standalone)
  --hardware HW     tncs | modems
  --device DEV      tnc2c | pktnc2 | baycom-ser12 | baycom-par96 | baycom-kiss

Examples:
  max25-ctl discover
  max25-ctl build
  max25-ctl start --hardware tncs --device tnc2c
  max25-ctl start --hardware modems --device baycom-ser12
  max25-ctl test
EOF
}

parse_opts() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mode) MODE="$2"; shift 2 ;;
      --hardware) HARDWARE="$2"; shift 2 ;;
      --device) DEVICE="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
    esac
  done
}

cmd_discover() {
  bash "${ROOT}/scripts/discover-plugins.sh" "$@"
}

cmd_build() {
  bash "${ROOT}/scripts/build-all.sh"
}

cmd_start() {
  parse_opts "$@"
  case "$HARDWARE" in
    tncs)
      case "$DEVICE" in
        tnc2c|"") echo "TNC2C boot-wait — power-cycle TNC while script runs"; exec "${ROOT}/stacks/tncs/tnc2c-boot-wait.sh" ;;
        pktnc2) exec "${ROOT}/stacks/tncs/pktnc2-boot-wait.sh" ;;
        *) echo "Unknown TNC device: $DEVICE" >&2; exit 1 ;;
      esac
      ;;
    modems)
      echo "BayCom PR-Stack start (root required)"
      exec sudo "${ROOT}/stacks/baycom-pr/scripts/baycom-pr-ctl" preflight
      sudo "${ROOT}/stacks/baycom-pr/scripts/baycom-pr-ctl" start
      ;;
    "")
      echo "Specify --hardware tncs|modems" >&2
      exit 1
      ;;
    *)
      echo "Unknown hardware: $HARDWARE" >&2
      exit 1
      ;;
  esac
}

cmd_stop() {
  parse_opts "$@"
  if [[ "$HARDWARE" == "modems" || -z "$HARDWARE" ]]; then
    sudo "${ROOT}/stacks/baycom-pr/scripts/baycom-pr-ctl" stop 2>/dev/null || true
  fi
  echo "TNC serial: release port (stop HyBBX/minicom on device)"
}

cmd_status() {
  parse_opts "$@"
  echo "MainAX25 mode: $MODE"
  bash "${ROOT}/scripts/discover-plugins.sh" --type device
  if [[ -x "${ROOT}/stacks/baycom-pr/scripts/baycom-pr-ctl" ]]; then
    sudo "${ROOT}/stacks/baycom-pr/scripts/baycom-pr-ctl" status 2>/dev/null || echo "baycom-pr: not running or no root"
  fi
}

cmd_test() {
  echo "-- TNCs stack --"
  make -C "${ROOT}/stacks/tncs" test 2>/dev/null || true
  echo "-- BayCom PR stack --"
  make -C "${ROOT}/stacks/baycom-pr" test
}

case "$ACTION" in
  help|-h|--help) usage ;;
  discover) cmd_discover "$@" ;;
  build) cmd_build ;;
  start) cmd_start "$@" ;;
  stop) cmd_stop "$@" ;;
  status) cmd_status "$@" ;;
  test) cmd_test ;;
  *) echo "Unknown command: $ACTION" >&2; usage; exit 1 ;;
esac
