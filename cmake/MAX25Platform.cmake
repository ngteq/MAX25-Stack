# MAX25 platform defaults — Linux full stack, FreeBSD server + CRDOP/OSS

set(MAX25_SYSTEM "${CMAKE_SYSTEM_NAME}")

if(CMAKE_SYSTEM_NAME STREQUAL "Linux")
    set(MAX25_PLATFORM "linux")
    set(MAX25_DEFAULT_BUILD_TNCS ON)
    set(MAX25_DEFAULT_BUILD_BCPR ON)
elseif(CMAKE_SYSTEM_NAME STREQUAL "FreeBSD")
    set(MAX25_PLATFORM "freebsd")
    set(MAX25_DEFAULT_BUILD_TNCS OFF)
    set(MAX25_DEFAULT_BUILD_BCPR ON)
elseif(CMAKE_SYSTEM_NAME MATCHES "OpenBSD|NetBSD|DragonFly")
    set(MAX25_PLATFORM "bsd")
    set(MAX25_DEFAULT_BUILD_TNCS OFF)
    set(MAX25_DEFAULT_BUILD_BCPR OFF)
else()
    set(MAX25_PLATFORM "generic")
    set(MAX25_DEFAULT_BUILD_TNCS OFF)
    set(MAX25_DEFAULT_BUILD_BCPR OFF)
endif()

if(NOT DEFINED MAX25_BUILD_TNCS)
    set(MAX25_BUILD_TNCS ${MAX25_DEFAULT_BUILD_TNCS} CACHE BOOL "Build stacks/tncs tools")
endif()
if(NOT DEFINED MAX25_BUILD_BCPR)
    set(MAX25_BUILD_BCPR ${MAX25_DEFAULT_BUILD_BCPR} CACHE BOOL "Build stacks/bcpr userspace BayCom/based SER12")
endif()

message(STATUS "MAX25 platform=${MAX25_PLATFORM} system=${MAX25_SYSTEM}")
