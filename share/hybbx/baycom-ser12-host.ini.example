; LEGACY EXAMPLE — do not use for UN1TME production (TNCs only).
; BayCom/based on MAX25: prefer stacks/bcpr (bcprd / [features] bcpr=yes).
; Kernel baycom_ser_fdx / bcsf* is not the product path.
; Optional non-UN1TME HyBBX sites: attach BayCom/based only via MAX25 after bcpr prove-out.
; This file kept for historical Secondary/kernel experiments only.

[networks]
baycom = no
ax25 = yes

; --- obsolete kernel SER12 sketch (do not enable on UN1TME) ---
; [transport.baycom1]
; backend = kernel
; mode = ser12*
; interface = bcsf0
; iobase = 0x3f8
; irq = 4
; radio_baud = 1200
; Prefer instead: max25d device bcpr-bc0 = bcpr:bc0 + /etc/max25/bcpr.ini
