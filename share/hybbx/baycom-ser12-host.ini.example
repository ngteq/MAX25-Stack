; MainAX25-Stack (MAX25-Stack) — HyBBX Secondary host (BayCom SER12)
; Requires max25d [features] baycom=yes and MAX25 BayCom prep.
; HyBBX: use packet_radio + kiss_entry=none (not transport.baycom — runtime default off).
; Legacy transport.baycom below — enable only with [networks] baycom=yes and explicit operator need.

[networks]
baycom = no
ax25 = yes

[transport.baycom1]
backend = kernel
mode = ser12*
interface = bcsf0
iobase = 0x3f8
irq = 4
radio_baud = 1200
txdelay = 30
slot = 10
persist = 128
txtail = 1
circuit_host = main.example.com
circuit_port = 7323
link_id = max25-baycom-ser12
link_password = changeme
frequency_mhz = 27.205
