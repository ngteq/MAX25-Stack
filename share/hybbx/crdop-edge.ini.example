; MainAX25-Stack (MAX25-Stack) — HyBBX Secondary edge (CRDOP / soft-crdrop)
; Merge into HyBBX hybbx.ini on Secondary node.
; Prerequisite: crdopc running (max25-ctl start --hardware soft-modems --device soft-crdrop)

[networks]
crdop = yes

[transport.crdop1]
enabled = yes
modem_host = 127.0.0.1
modem_port = 8515
mycall = CB-0
listen = yes
circuit_host = main.example.com
circuit_port = 7323
link_id = max25-crdop
link_password = changeme
