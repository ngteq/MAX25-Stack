; bcpr — BayCom/based PC-COM SER12 (userspace, MAX25)
; Public mark: BayCom/based. Never Konverter/converter.
; Hardware: TCM3105-class AFSK modem chip (bits↔tones + PTT). Not a TNC/digi/BBX.
; Host (bcprd/max25d) owns HDLC, KISS, bit clock → max25e0:bc0 / bc1.
; Product path: this plugin — not kernel baycom_ser_fdx. No calibrate.
; A–O–Z: isolate COM · real unique IRQ (never invent) · freeze INI after resolve · exclusive lock.
; Autoprobe only if serial missing/wrong — never when serial is correct.
; Prefer more config + probes (H11): serial + iobase + irq + mode mandatory when known.
;
; Smoke prove-out (nofreeze):
;   bcpr-ctl -c stacks/bcpr/share/bcpr.ini.example smoke              # L0 offline, NO TX
;   bcpr-ctl -c /etc/max25/bcpr.ini smoke --live --seconds 15         # L2/L3 RX
;   bcpr-ctl -c /etc/max25/bcpr.ini smoke --live --tx --seconds 15    # L4 optional TX
; Vault SSoT: 0-RESEARCHES/projects/max25-stack/2026-07-18-bcpr-rxtx-smoke-nofreeze.md
;
; Quick start (offline):
;   bcprd -c stacks/bcpr/share/bcpr.ini.example --dry-run --once
; Live: copy to /etc/max25/bcpr.ini or ./local/bcpr.ini; set dry_run=no; match real IRQ.

[bcpr]
dry_run = yes
state_dir = /tmp/bcpr

[bc0]
enabled = yes
serial = /dev/ttyS0
iobase = 0x3f8
irq = 4
mode = ser12*
baud = 1200
kiss_link = /tmp/bcpr/kiss-bc0
tx_delay = 35
tx_tail = 2
slottime = 10
ppersist = 40
fulldup = no

; [bc1] — optional second device (max 2)
; enabled = yes
; serial = /dev/ttyS1
; iobase = 0x2f8
; irq = 3
; mode = ser12*
; kiss_link = /tmp/bcpr/kiss-bc1
