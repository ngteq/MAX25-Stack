; MainAX25-Stack — max25d daemon (Linux only)
; Copy to /etc/max25/max25d.ini or pass MAX25D_INI=

[daemon]
; Operating mode: standalone | service | hybbx-edge
mode = standalone
; Default hardware stack (per-device override in [serial.<id>] if needed)
hardware = tncs
; Legacy single-device id (used when [devices] is absent)
device = tnc2c

[devices]
; Multi-device: one KissBridge per id (5+ supported). Serial path or empty = env default.
default = tnc2c
tnc2c = /dev/ttyS4
pktnc2 = /dev/ttyS5
; enabled = tnc2c,pktnc2   ; optional — omit to enable all listed ids

[network]
; Terminal clients connect here (TCP). Unix socket always enabled on Linux.
tcp_host = 0.0.0.0
tcp_port = 7325
unix_socket = /run/max25/modem.sock
; Plain-text TCP auth for remote terminals (empty = disabled; Unix socket exempt)
tcp_password =

[modem]
; Default IDs — terminal may override live (session scope)
callerid = CB-0
callid = QST
; Send lines as AX.25 UI when yes
ax25_ui = yes

[stack]
; Auto-start hardware on daemon start (boot-wait per enabled device)
auto_start = yes

[serial]
; Legacy single-device overrides — ignored when [devices] is present.
; device = /dev/ttyS4
; baud = 19200
; line = 8n1
; dtr_rts = yes
; kiss_entry = kiss_on

[serial.tnc2c]
; Per-device serial profile (optional — defaults from stacks/tncs/tnc2c-serial.env)
; baud = 19200
; line = 8n1
; dtr_rts = yes
; kiss_entry = kiss_on

[serial.pktnc2]
; pktnc2: 9600 8N1, DTR+RTS off, kiss_entry=auto
; baud = 9600
; line = 8n1
; dtr_rts = no
; kiss_entry = auto
