# Landolt TNC2C on /dev/ttyS4 — CONFIRMED 2026-07-10
# Host: NORD><LINK Firmware 2.7b (EPROM T2.7b.10)
# 19200 8N1 — NOT 7E1, NOT 4800
# Boot: ./tnc2c-boot-wait.sh (DTR high during power-on) → OK: HOST
TNC2C_DEV=/dev/ttyS4
TNC2C_BAUD=19200
TNC2C_LINE=8n1
TNC2C_RADIO_BAUD=2400
TNC2C_MODEM=tcm3105
HYBBX_SERIAL_LINE=8n1
