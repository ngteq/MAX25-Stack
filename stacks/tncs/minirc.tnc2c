# minicom - TNC2C host direct (/dev/ttyS4)
# Only when HyBBX is OFF! Otherwise port is in use.
# Install: mkdir -p ~/.minicom && cp minirc.tnc2c ~/.minicom/minirc.tnc2c
# Start:   minicom tnc2c

pu port             /dev/ttyS4
pu baudrate         19200
pu bits             8
pu parity           N
pu stopbits         1
pu rtscts           No
pu xonxoff          No
pu local_echo       No
