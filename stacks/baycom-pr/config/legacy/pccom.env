# PC-COM / baycom_ser_fdx — default profile (modem A on ttyS0)
# Other modem: config/pccom.env.modem-b  ->  pccom-ctl -f modem-b start

PCCOM_PROFILE=modem-a
PCCOM_LABEL="Modem A (ttyS0)"

PCCOM_ROOT=/opt/baycom-pr
PCCOM_BINDIR=/usr/local/sbin

PCCOM_SERIAL=/dev/ttyS0
PCCOM_IOBASE=0x3f8
PCCOM_IRQ=4

# Kernel network interface created by baycom_ser_fdx
PCCOM_IFACE=bcsf0
PCCOM_BAUD=1200

# AE 8000 recommended TX delay: 350 ms = 35 * 10 ms (pccom_sethdlc units)
PCCOM_TXD=35

# AX.25 port name in /etc/baycom/axports/axports
PCCOM_PORT=cb0
PCCOM_CALL=CB-0

# Runtime state (created by pccom-ctl)
PCCOM_STATE_DIR=/var/run/pccom
PCCOM_KISS_LINK=${PCCOM_STATE_DIR}/kiss
PCCOM_PID_BAYCOM=${PCCOM_STATE_DIR}/baycom.pid
PCCOM_PID_BRIDGE=${PCCOM_STATE_DIR}/kissbridge.pid

# baycom_ser_fdx module options
PCCOM_MODE="ser12*"

# KISS bridge (protocol=kiss on this device path)
PCCOM_KISS_BRIDGE=yes
