# BayCom PR-Stack — KISS PTY (stack must be running)
# Usage: baycom-pr-ctl minicom a
#        minicom baycom-kiss -D /var/run/baycom-pr/kiss-a
#
# PTY is byte-oriented; baud is nominal. Use for KISS clients or inspection.

pu port              /var/run/baycom-pr/kiss-a
pu baudrate          9600
pu bits              8
pu parity            None
pu stopbits          1
pu rtscts            No
pu xonxoff           No
